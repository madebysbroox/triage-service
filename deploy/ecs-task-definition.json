{
  "family": "triage-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<account-id>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<account-id>:role/triage-service-task-role",
  "containerDefinitions": [
    {
      "name": "triage-service",
      "image": "replace-me",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "prod"
        },
        {
          "name": "TRIAGE_PROVIDER",
          "value": "bedrock"
        },
        {
          "name": "TRIAGE_MODEL_ID",
          "value": "anthropic.claude-3-5-sonnet-20240620-v1:0"
        }
      ],
      "secrets": [
        {
          "name": "TRIAGE_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:triage-service/api-key"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/triage-service",
          "awslogs-region": "<region>",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8080/actuator/health/readiness || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
